# Copy to .env and fill in values. Never commit .env.

# ── Auth ──────────────────────────────────────────────────────────────────────
# Protects the API endpoints — use a long random string
API_KEY=generate-a-long-random-string-here

# ── Alpaca ────────────────────────────────────────────────────────────────────
# From alpaca.markets → API Keys (paper or live)
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key

# ── Supabase ──────────────────────────────────────────────────────────────────
# From supabase.com → project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# ── Kronos model ──────────────────────────────────────────────────────────────
# mini=4M params (fastest), small=25M (recommended), base=102M (slowest on CPU)
KRONOS_MODEL=NeoQuasar/Kronos-small
KRONOS_TOKENIZER=NeoQuasar/Kronos-Tokenizer-base

# ── Portfolio ─────────────────────────────────────────────────────────────────
# Tickers to score on /score/portfolio — match your options-tracker stocks
PORTFOLIO_TICKERS=AMAT,ANET,BE,CEG,CL,CRWD,DDOG,MDB,ORCL,PLTR,VRT,ZS,OKLO,RGTI,SMR,PATH,DLR,EQIX,MRVL,NOW

# Prediction horizon in trading days
PRED_DAYS=10

# Historical lookback in calendar days fed to Kronos (max 512 tokens = ~2 years daily)
LOOKBACK_DAYS=130

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call this API from a browser
CORS_ORIGINS=https://options-tracker.vercel.app,http://localhost:3000
